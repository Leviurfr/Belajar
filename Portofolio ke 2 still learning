  /* ---------------------------------------------------------
     SCROLL PROGRESS BAR
     --------------------------------------------------------- */
  function initScrollProgress(){
    var bar = document.getElementById('scrollProgress');
    if (!bar) return;
    function update(){
      var doc = document.documentElement;
      var scrollTop = doc.scrollTop || document.body.scrollTop;
      var scrollHeight = doc.scrollHeight - doc.clientHeight;
      var pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      bar.style.width = pct + '%';
    }
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }

  /* ---------------------------------------------------------
     BAHASA / ANIMASI BARU: CANVAS INTERACTIVE PARTICLES
     --------------------------------------------------------- */
  function initParticleCanvas(){
    var canvas = document.getElementById('particleCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    
    var particles = [];
    var maxParticles = 65;
    var mouse = { x: null, y: null, radius: 140 };

    if(prefersReducedMotion) return;

    window.addEventListener('mousemove', function(e){
      var rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });

    window.addEventListener('mouseleave', function(){
      mouse.x = null;
      mouse.y = null;
    });

    function resizeCanvas(){
      var parent = canvas.parentElement;
      canvas.width = parent.offsetWidth;
      canvas.height = parent.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    class Particle {
      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.vx = (Math.random() - 0.5) * 0.45;
        this.vy = (Math.random() - 0.5) * 0.45;
        this.radius = Math.random() * 2 + 1;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;

        if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

        if (mouse.x !== null && mouse.y !== null) {
          var dx = this.x - mouse.x;
          var dy = this.y - mouse.y;
          var dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < mouse.radius) {
            var force = (mouse.radius - dist) / mouse.radius;
            this.x += (dx / dist) * force * 2;
            this.y += (dy / dist) * force * 2;
          }
        }
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(79, 209, 197, 0.4)';
        ctx.fill();
      }
    }

    for (var i = 0; i < maxParticles; i++) {
      particles.push(new Particle());
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();

        for (var j = i + 1; j < particles.length; j++) {
          var dx = particles[i].x - particles[j].x;
          var dy = particles[i].y - particles[j].y;
          var dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 100) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = 'rgba(242, 181, 68,' + (1 - dist/100) * 0.12 + ')';
            ctx.lineWidth = 0.8;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animate);
    }
    animate();
  }

  /* ---------------------------------------------------------
     INTRO / PRELOADER
     --------------------------------------------------------- */
  function initIntro(){
    var introEl = document.getElementById('intro');
    if (!introEl) return;

    var typeLine1   = document.getElementById('typeLine1');
    var typeLine2   = document.getElementById('typeLine2');
    var introLine1  = document.getElementById('introLine1');
    var introLine2  = document.getElementById('introLine2');
    var introName   = document.getElementById('introName');
    var introRole   = document.getElementById('introRole');
    var introBarFill= document.getElementById('introBarFill');
    var introBarPct = document.getElementById('introBarPct');
    var introSkip   = document.getElementById('introSkip');

    var skipped = false;
    var finished = false;

    function sleep(ms){
      return new Promise(function(resolve){
        var done = false;
        var t, p;
        function finishWait(){
          if (!done){ done = true; clearTimeout(t); clearInterval(p); resolve(); }
        }
        t = setTimeout(finishWait, ms);
        p = setInterval(function(){ if (skipped) finishWait(); }, 30);
      });
    }

    function typeText(el, text, speed){
      speed = speed || 55;
      return new Promise(function(resolve){
        var i = 0;
        el.textContent = '';
        var id = setInterval(function(){
          if (skipped){ clearInterval(id); el.textContent = text; resolve(); return; }
          i++;
          el.textContent = text.slice(0, i);
          if (i >= text.length){ clearInterval(id); resolve(); }
        }, speed);
      });
    }

    function revealEl(el){
      gsap.to(el, { opacity: 1, y: 0, duration: .6, ease: 'power3.out' });
    }

    function fillBar(){
      return new Promise(function(resolve){
        var resolved = false;
        function done(){ if (!resolved){ resolved = true; clearInterval(watcher); resolve(); } }
        gsap.to(introBarFill, {
          width: '100%', duration: .9, ease: 'power1.inOut',
          onUpdate: function(){
            var w = parseFloat(introBarFill.style.width) || 0;
            if (introBarPct) introBarPct.textContent = Math.round(w) + '%';
          },
          onComplete: done
        });
        var watcher = setInterval(function(){
          if (skipped){
            gsap.killTweensOf(introBarFill);
            introBarFill.style.width = '100%';
            if (introBarPct) introBarPct.textContent = '100%';
            done();
          }
        }, 30);
      });
    }

    function playExit(){
      var tl = gsap.timeline({
        onComplete: function(){
          introEl.style.display = 'none';
          document.body.classList.remove('lock-scroll');
        }
      });
      tl.to(introEl, { yPercent: -100, duration: 1, ease: 'power4.inOut' })
        .from('.navbar', { y: -20, opacity: 0, duration: .6, ease: 'power3.out' }, '-=0.5')
        .from('.hero__eyebrow', { y: 14, opacity: 0, duration: .5, ease: 'power3.out' }, '-=0.3')
        .from('.hero-title .line', { y: 36, opacity: 0, duration: .7, ease: 'power3.out', stagger: .08 }, '-=0.3')
        .from('.hero-sub', { y: 14, opacity: 0, duration: .5, ease: 'power3.out' }, '-=0.35')
        .from('.hero-cta .btn', { y: 14, opacity: 0, duration: .5, ease: 'power3.out', stagger: .1 }, '-=0.3')
        .from('.hero-meta', { opacity: 0, duration: .6 }, '-=0.4')
        .from('.hero__visual', { opacity: 0, scale: .92, duration: .7, ease: 'power3.out' }, '-=0.5')
        .from('.scroll-cue', { opacity: 0, duration: .5 }, '-=0.2');
    }

    function finish(){
      if (finished) return;
      finished = true;
      skipped = true;
      typeLine1.textContent = 'whoami';
      typeLine2.textContent = 'role --current';
      gsap.set(introName, { opacity: 1, y: 0 });
      gsap.set(introRole, { opacity: 1, y: 0 });
      gsap.killTweensOf(introBarFill);
      introBarFill.style.width = '100%';
      if (introBarPct) introBarPct.textContent = '100%';
      playExit();
    }

    if (introSkip) introSkip.addEventListener('click', finish);

    var safety = setTimeout(finish, 9000);

    (function run(){
      var p;
      if (prefersReducedMotion){
        typeLine1.textContent = 'whoami';
        typeLine2.textContent = 'role --current';
        gsap.set(introName, { opacity: 1, y: 0 });
        gsap.set(introRole, { opacity: 1, y: 0 });
        introBarFill.style.width = '100%';
        if (introBarPct) introBarPct.textContent = '100%';
        p = sleep(300);
      } else {
        p = typeText(typeLine1, 'whoami')
          .then(function(){
            if (skipped) return;
            revealEl(introName);
            return sleep(450);
          })
          .then(function(){
            if (skipped) return;
            introLine1.classList.remove('is-active');
            introLine2.classList.add('is-active');
            return typeText(typeLine2, 'role --current');
          })
          .then(function(){
            if (skipped) return;
            introLine2.classList.remove('is-active');
            revealEl(introRole);
            return sleep(380);
          })
          .then(function(){
            if (skipped) return;
            return fillBar();
          })
          .then(function(){
            return sleep(250);
          });
      }

      p.then(function(){
        clearTimeout(safety);
        finish();
      }).catch(function(){
        finish();
      });
    })();
  }

  /* ---------------------------------------------------------
     NAVBAR (scroll state, mobile toggle, active link)
     --------------------------------------------------------- */
  function initNav(){
    var navbar   = document.getElementById('navbar');
    var toggle   = document.getElementById('navToggle');
    var links    = document.getElementById('navLinks');
    var linkEls  = document.querySelectorAll('.navbar__link');

    function closeMenu(){
      links.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('menu-open');
    }

    if (toggle && links){
      toggle.addEventListener('click', function(){
        var isOpen = links.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(isOpen));
        document.body.classList.toggle('menu-open', isOpen);
      });
    }

    linkEls.forEach(function(a){
      a.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape') closeMenu();
    });

    window.addEventListener('scroll', function(){
      navbar.classList.toggle('navbar--scrolled', window.scrollY > 12);
    }, { passive: true });

    if ('IntersectionObserver' in window){
      var sections = document.querySelectorAll('main section[id]');
      var observer = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if (entry.isIntersecting){
            linkEls.forEach(function(a){
              a.classList.toggle('active', a.getAttribute('data-nav') === entry.target.id);
            });
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      sections.forEach(function(s){ observer.observe(s); });
    }
  }

