<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Muhammad Fahlevi — Frontend Developer Portfolio</title>
<meta name="description" content="Portfolio of Muhammad Fahlevi, a Frontend Developer focused on clean code, motion, and detail-driven interfaces.">
<meta name="theme-color" content="#0b0e14">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%230b0e14'/><text x='50' y='65' font-family='monospace' font-weight='bold' font-size='40' fill='%23f2b544' text-anchor='middle'>MF</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<noscript><style>#intro{display:none !important;}body{overflow:auto !important;height:auto !important;}</style></noscript>

<style>
/* ============================================================
   0. TOKENS & RESET
   ============================================================ */
:root{
  --bg-base:#0b0e14;
  --bg-panel:#11151c;
  --bg-elevated:#161b24;
  --line: rgba(232,230,225,.09);
  --line-strong: rgba(232,230,225,.16);
  --text:#e8e6e1;
  --text-muted:#8b95a3;
  --text-dim:#717b8a;
  --amber:#f2b544;
  --amber-dim: rgba(242,181,68,.14);
  --teal:#4fd1c5;
  --teal-dim: rgba(79,209,197,.16);
  --radius:12px;
  --maxw:1180px;
  --ff-display:'Space Grotesk', sans-serif;
  --ff-body:'IBM Plex Sans', sans-serif;
  --ff-mono:'IBM Plex Mono', monospace;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg-base);
  color:var(--text);
  font-family:var(--ff-body);
  line-height:1.65;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
body.lock-scroll{overflow:hidden;height:100vh;}
body.menu-open{overflow:hidden;}
body.has-custom-cursor{cursor:none;}
img{max-width:100%;display:block;height:auto;}
a{color:inherit;text-decoration:none;}
ul{list-style:none;}
button{font-family:inherit;border:none;background:none;cursor:pointer;color:inherit;}
input,textarea{font-family:inherit;font-size:1rem;color:inherit;}
::selection{background:var(--amber);color:var(--bg-base);}
:focus-visible{outline:2px solid var(--amber);outline-offset:3px;border-radius:4px;}
.dim{color:var(--text-dim);}

@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto;}
  *{animation-duration:.001ms !important;animation-iteration-count:1 !important;transition-duration:.001ms !important;}
}

/* ambient grid texture & canvas */
.grid-overlay{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(var(--line) 1px, transparent 1px),
    linear-gradient(90deg, var(--line) 1px, transparent 1px);
  background-size:46px 46px;
  -webkit-mask-image:radial-gradient(ellipse 85% 65% at 50% 0%, black 35%, transparent 85%);
  mask-image:radial-gradient(ellipse 85% 65% at 50% 0%, black 35%, transparent 85%);
}
#particleCanvas {
  position: absolute;inset: 0;z-index: 0;pointer-events: none;
}

/* scroll progress bar */
.scroll-progress{
  position:fixed;top:0;left:0;height:3px;width:0%;z-index:250;pointer-events:none;
  background:linear-gradient(90deg,var(--amber),var(--teal));
}

/* custom cursor */
.cursor-dot,.cursor-ring{position:fixed;top:0;left:0;border-radius:50%;pointer-events:none;z-index:300;display:none;}
.cursor-dot{width:6px;height:6px;background:var(--amber);}
.cursor-ring{width:34px;height:34px;border:1px solid var(--line-strong);transition:width .25s,height .25s,border-color .25s,background .25s;}
.cursor-ring.is-active{width:54px;height:54px;border-color:var(--amber);background:var(--amber-dim);}
body.has-custom-cursor .cursor-dot,body.has-custom-cursor .cursor-ring{display:block;}

/* ============================================================
   1. LAYOUT PRIMITIVES
   ============================================================ */
.section{padding:clamp(80px,12vw,140px) 0;position:relative;z-index:1;}
.section__inner{max-width:var(--maxw);margin:0 auto;padding:0 clamp(20px,6vw,48px);}
.eyebrow{
  font-family:var(--ff-mono);font-size:.8rem;letter-spacing:.06em;
  color:var(--amber);margin-bottom:1.1em;display:inline-block;
}
.section__title{
  font-family:var(--ff-display);font-weight:700;letter-spacing:-.02em;
  font-size:clamp(2rem,5vw,2.7rem);margin-bottom:.55em;
}
.section__lead{color:var(--text-muted);max-width:560px;font-size:1.02rem;margin-bottom:2.5rem;}

.btn{
  display:inline-flex;align-items:center;gap:.5em;
  font-family:var(--ff-body);font-weight:500;font-size:.96rem;
  padding:.85em 1.7em;border-radius:var(--radius);
  transition:box-shadow .25s ease, border-color .25s ease, color .25s ease;
  will-change:transform;
}
.btn--primary{background:var(--amber);color:var(--bg-base);}
.btn--primary:hover{box-shadow:0 14px 30px -10px var(--amber-dim);}
.btn--ghost{border:1px solid var(--line-strong);color:var(--text);}
.btn--ghost:hover{border-color:var(--amber);color:var(--amber);}

.status-dot{
  display:inline-block;width:8px;height:8px;border-radius:50%;
  background:var(--teal);margin-right:.5em;
  animation:pulse 2s infinite;
}
@keyframes pulse{
  0%{box-shadow:0 0 0 0 rgba(79,209,197,.55);}
  70%{box-shadow:0 0 0 9px rgba(79,209,197,0);}
  100%{box-shadow:0 0 0 0 rgba(79,209,197,0);}
}

/* ============================================================
   2. INTRO / PRELOADER
   ============================================================ */
.intro{
  position:fixed;inset:0;z-index:200;background:var(--bg-base);
  display:flex;align-items:center;justify-content:center;padding:24px;
}
.intro__terminal{width:min(620px,90vw);font-family:var(--ff-mono);}
.intro__line{
  color:var(--text-muted);font-size:.95rem;margin-bottom:.5em;
  display:flex;gap:.55em;align-items:baseline;min-height:1.4em;
}
.intro__prompt{color:var(--amber);}
.intro__cursor{
  display:inline-block;width:.55em;height:1.05em;background:var(--text-muted);
  margin-left:1px;opacity:0;
}
.intro__line.is-active .intro__cursor{opacity:1;animation:blink 1s steps(1) infinite;}
@keyframes blink{50%{opacity:0;}}
.intro__name{
  font-family:var(--ff-display);font-weight:700;letter-spacing:-.02em;
  font-size:clamp(1.7rem,7vw,3.1rem);margin:.3em 0 .85em;color:var(--text);
  opacity:0;transform:translateY(8px);
}
.intro__role{
  font-family:var(--ff-mono);color:var(--teal);
  font-size:clamp(1rem,3vw,1.25rem);margin-bottom:1.7em;
  opacity:0;transform:translateY(8px);
}
.intro__bar-row{display:flex;align-items:center;gap:14px;}
.intro__bar{flex:1;height:3px;background:var(--line-strong);border-radius:2px;overflow:hidden;}
.intro__bar-fill{width:0%;height:100%;background:linear-gradient(90deg,var(--amber),var(--teal));}
.intro__bar-pct{font-size:.75rem;color:var(--text-dim);width:3.4em;text-align:right;}
.intro__skip{
  position:absolute;bottom:26px;right:26px;
  font-family:var(--ff-mono);font-size:.78rem;color:var(--text-dim);
  border:1px solid var(--line-strong);padding:.55em 1em;border-radius:999px;
  transition:color .2s,border-color .2s;
}
.intro__skip:hover{color:var(--text);border-color:var(--text-dim);}

/* ============================================================
   3. NAVBAR
   ============================================================ */
.navbar{
  position:fixed;top:0;left:0;right:0;z-index:100;
  border-bottom:1px solid transparent;
  background:transparent;
  transition:background .3s ease, border-color .3s ease;
}
.navbar--scrolled{
  background:rgba(11,14,20,.74);
  -webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);
  border-bottom:1px solid var(--line);
}
.navbar__inner{
  max-width:var(--maxw);margin:0 auto;
  padding:18px clamp(20px,6vw,48px);
  display:flex;align-items:center;justify-content:space-between;
}
.navbar__logo{display:flex;align-items:center;gap:.65em;}
.navbar__logo-badge{
  width:34px;height:34px;border-radius:8px;
  background:linear-gradient(135deg,var(--amber),var(--teal));
  display:flex;align-items:center;justify-content:center;
  font-family:var(--ff-mono);font-weight:700;font-size:.82rem;color:var(--bg-base);
  flex-shrink:0;cursor:pointer;
}
.navbar__logo-text{font-family:var(--ff-mono);font-size:.95rem;color:var(--text);}
.navbar__links{display:flex;align-items:center;gap:1.5rem;}
.navbar__link{
  font-family:var(--ff-mono);font-size:.88rem;color:var(--text-muted);
  transition:color .2s ease;
}
.navbar__link .br{color:var(--text-dim);transition:color .2s ease;}
.navbar__link:hover,.navbar__link.active{color:var(--text);}
.navbar__link:hover .br,.navbar__link.active .br{color:var(--amber);}
.navbar__toggle{
  display:none;flex-direction:column;justify-content:center;gap:5px;
  width:36px;height:36px;
}
.navbar__toggle span{display:block;width:100%;height:2px;background:var(--text);transition:transform .3s ease, opacity .3s ease;}
.navbar__toggle[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.navbar__toggle[aria-expanded="true"] span:nth-child(2){opacity:0;}
.navbar__toggle[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

@media (min-width:921px){
  .navbar__link{position:relative;}
  .navbar__link::after{
    content:'';position:absolute;left:0;right:0;bottom:-6px;height:2px;
    background:linear-gradient(90deg,var(--amber),var(--teal));
    transform:scaleX(0);transform-origin:left;transition:transform .3s ease;
  }
  .navbar__link:hover::after,.navbar__link.active::after{transform:scaleX(1);}
}

@media (max-width:920px){
  .navbar__links{
    position:absolute;top:100%;left:0;right:0;
    flex-direction:column;align-items:stretch;gap:0;
    background:rgba(11,14,20,.97);
    -webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
    max-height:0;overflow:hidden;
    transition:max-height .35s ease;
  }
  .navbar__links.is-open{max-height:380px;}
  .navbar__link{padding:16px clamp(20px,6vw,48px);border-bottom:1px solid var(--line);width:100%;}
  .navbar__toggle{display:flex;}
}

/* ============================================================
   4. HERO
   ============================================================ */
.section.hero{
  padding:0;min-height:100vh;display:flex;align-items:center;
  overflow:hidden;
}
.hero__decor{position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
.hero__glyph{
  position:absolute;top:-4vw;right:-2vw;
  font-family:var(--ff-mono);font-weight:500;line-height:1;
  font-size:clamp(8rem,22vw,17rem);color:var(--line-strong);user-select:none;
}
.hero__blob{
  position:absolute;width:42vw;height:42vw;max-width:520px;max-height:520px;
  left:58%;top:46%;transform:translate(-50%,-50%);
  background:radial-gradient(circle, var(--amber-dim), transparent 70%);
  filter:blur(40px);animation:float 14s ease-in-out infinite;
}
@keyframes float{
  0%,100%{transform:translate(-55%,-45%) scale(1);}
  50%{transform:translate(-45%,-55%) scale(1.08);}
}
.hero__inner{position:relative;z-index:1;padding-top:96px;width:100%;}
.hero__grid{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(24px,5vw,64px);align-items:center;}
.hero__eyebrow{
  font-family:var(--ff-mono);font-size:.88rem;color:var(--text-muted);margin-bottom:1.3em;
}
.hero-title{font-family:var(--ff-display);font-weight:700;letter-spacing:-.03em;line-height:.98;}
.hero-title .line{display:block;font-size:clamp(2.8rem,9vw,5.4rem);white-space:nowrap;}
.hero-title .letter{display:inline-block;transition:transform .25s ease, color .25s ease;}
.hero-title .letter:hover{transform:translateY(-6px) rotate(-4deg);color:var(--amber);}
.hero-sub{
  margin:1.4em 0 1.8em;max-width:560px;color:var(--text-muted);font-size:1.08rem;
}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2.6em;}
.hero-meta{display:flex;gap:1.8rem;flex-wrap:wrap;}
.hero-meta__item{
  font-family:var(--ff-mono);font-size:.82rem;color:var(--text-muted);
  display:flex;align-items:center;
}

/* hero photo / visual */
.hero__visual{position:relative;display:flex;align-items:center;justify-content:center;padding:20px;}
.hero__orbit{position:absolute;inset:-30px;pointer-events:none;}
.orbit-ring{position:absolute;border:1px dashed var(--line-strong);}
.orbit-ring--1{inset:-16px;border-radius:46px;animation:spin 20s linear infinite;}
.orbit-ring--2{inset:-36px;border-radius:60px;border-style:dotted;animation:spin 28s linear infinite reverse;}
@keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.orbit-chip{
  position:absolute;font-family:var(--ff-mono);font-size:.74rem;
  background:var(--bg-elevated);border:1px solid var(--line-strong);
  padding:.5em .85em;border-radius:999px;color:var(--text);
  display:flex;align-items:center;gap:.4em;white-space:nowrap;
  box-shadow:0 14px 30px -16px rgba(0,0,0,.55);
  animation:chipFloat 5s ease-in-out infinite;
}
.chip--1{top:4%;left:-14%;animation-delay:.2s;}
.chip--2{bottom:8%;right:-16%;animation-delay:1.1s;}
.chip--3{top:48%;right:-20%;animation-delay:2s;}
@keyframes chipFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}

.hero__photo-frame{
  position:relative;width:min(320px,80%);aspect-ratio:4/5;
  border-radius:32px;overflow:hidden;
  border:1px solid var(--line-strong);background:var(--bg-panel);
  box-shadow:0 40px 80px -30px rgba(0,0,0,.65);
}
.hero__photo{
  width:100%;height:100%;object-fit:cover;
  filter:grayscale(1) contrast(1.05);
  mix-blend-mode:luminosity;
}
.hero__photo-frame::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(160deg, var(--amber-dim), transparent 50%, var(--teal-dim));
  mix-blend-mode:color;
}
.hero__photo-tag{
  position:absolute;left:50%;bottom:14px;transform:translateX(-50%);
  font-family:var(--ff-mono);font-size:.68rem;letter-spacing:.03em;
  color:var(--text);background:rgba(11,14,20,.78);
  border:1px solid var(--line-strong);padding:.4em .9em;border-radius:999px;
  -webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);white-space:nowrap;
}

@media (max-width:900px){
  .hero__grid{grid-template-columns:1fr;gap:36px;}
}
@media (max-width:560px){
  .hero__orbit{display:none;}
  .hero__photo-frame{width:min(240px,68%);}
}

.scroll-cue{
  position:absolute;bottom:34px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:9px;
  color:var(--text-dim);z-index:1;
}
.scroll-cue__line{position:relative;width:1px;height:34px;background:var(--line-strong);overflow:hidden;}
.scroll-cue__line::after{
  content:'';position:absolute;top:0;left:0;width:100%;height:10px;background:var(--amber);
  animation:scrollDown 1.8s ease-in-out infinite;
}
@keyframes scrollDown{
  0%{transform:translateY(-10px);opacity:0;}
  50%{opacity:1;}
  100%{transform:translateY(34px);opacity:0;}
}
.scroll-cue__label{font-family:var(--ff-mono);font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;}

/* ============================================================
   4b. MARQUEE BAND
   ============================================================ */
.marquee-band{
  position:relative;z-index:1;background:var(--bg-panel);
  border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  padding:18px 0;overflow:hidden;
}
.marquee__track{
  display:flex;width:max-content;gap:2.2rem;align-items:center;
  animation:marqueeScroll 30s linear infinite;
}
.marquee-band:hover .marquee__track{animation-play-state:paused;}
.marquee__track span{
  font-family:var(--ff-mono);font-size:1.05rem;color:var(--text-muted);
  white-space:nowrap;letter-spacing:.04em;
}
.marquee__track .marquee__dot{color:var(--amber);}
@keyframes marqueeScroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ============================================================
   5. ABOUT
   ============================================================ */
.about__grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(32px,6vw,72px);align-items:start;margin-top:2.4em;perspective:1200px;}
.code-window{
  background:var(--bg-panel);border:1px solid var(--line);border-radius:var(--radius);
  overflow:hidden;box-shadow:0 30px 60px -30px rgba(0,0,0,.6);will-change:transform;
}
.code-window__bar{
  display:flex;align-items:center;gap:8px;padding:12px 16px;
  border-bottom:1px solid var(--line);background:var(--bg-elevated);
}
.code-window__dot{width:10px;height:10px;border-radius:50%;background:var(--c);}
.code-window__name{
  margin-left:auto;font-family:var(--ff-mono);font-size:.74rem;color:var(--text-dim);
}
.code-window__body{padding:22px 22px 26px;font-family:var(--ff-mono);font-size:.88rem;line-height:1.85;}
.code-window__body p{white-space:pre-wrap;color:var(--text-muted);}
.code-window__body p.indent{padding-left:1.4em;}
.tok-key{color:var(--teal);}
.tok-str{color:var(--amber);}
.code-window__cursor{
  display:inline-block;width:.5em;height:1em;background:var(--text-muted);
  vertical-align:-2px;animation:blink 1s steps(1) infinite;
}
.about__text p{color:var(--text-muted);margin-bottom:1.1em;}
.about__text p:first-of-type{color:var(--text);font-size:1.08rem;}
.about__props{
  margin-top:1.6em;border:1px solid var(--line);border-radius:var(--radius);
  background:var(--bg-panel);overflow:hidden;
}
.about__prop{
  display:flex;gap:1.5em;padding:14px 18px;border-bottom:1px solid var(--line);
  align-items:baseline;flex-wrap:wrap;
}
.about__prop:last-child{border-bottom:none;}
.about__prop dt{
  font-family:var(--ff-mono);font-size:.78rem;color:var(--text-dim);
  text-transform:uppercase;letter-spacing:.06em;width:90px;flex-shrink:0;
}
.about__prop dd{color:var(--text);font-size:.95rem;}

@media (max-width:860px){
  .about__grid{grid-template-columns:1fr;}
}

/* ============================================================
   6. STATS
   ============================================================ */
.stats__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;}
.stat-card{
  background:var(--bg-panel);border:1px solid var(--line);border-radius:var(--radius);
  padding:32px 22px;text-align:center;transition:border-color .3s ease;
}
.stat-card:hover{border-color:var(--teal);}
.stat-card__num{
  display:block;font-family:var(--ff-display);font-weight:700;
  font-size:clamp(2.2rem,5vw,3rem);color:var(--amber);letter-spacing:-.02em;
}
.stat-card__label{display:block;margin-top:.5em;font-family:var(--ff-mono);font-size:.8rem;color:var(--text-muted);}

/* ============================================================
   7. SERVICES
   ============================================================ */
.services__grid{
  display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:24px;
}
.service-card{
  background:var(--bg-panel);border:1px solid var(--line);border-radius:var(--radius);
  padding:32px 24px;transition:border-color .3s, transform .3s;
}
.service-card:hover{
  border-color:var(--teal);transform:translateY(-4px);
}
.service-card__icon{
  font-family:var(--ff-mono);font-size:1.5rem;color:var(--teal);margin-bottom:1rem;
}
.service-card__title{
  font-family:var(--ff-display);font-size:1.3rem;margin-bottom:.6rem;
}
.service-card__desc{color:var(--text-muted);font-size:.92rem;}

/* ============================================================
   8. PROJECTS
   ============================================================ */
.projects__grid{
  display:grid;grid-template-columns:repeat(auto-fit, minmax(320px, 1fr));gap:32px;margin-top:1rem;
  perspective:1200px;
}
.project-card{
  background:var(--bg-panel);border:1px solid var(--line);border-radius:var(--radius);
  overflow:hidden;box-shadow:0 20px 40px -20px rgba(0,0,0,0.5);
  transition:border-color 0.3s ease;will-change:transform;
}
.project-card:hover{
  border-color:var(--amber);
}
.project-card__img-wrapper{
  position:relative;width:100%;height:200px;overflow:hidden;background:var(--bg-elevated);
}
.project-card__img{
  width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease;
}
.project-card:hover .project-card__img{
  transform:scale(1.06);
}
.img-reveal-curtain{
  position:absolute;inset:0;z-index:2;background:var(--bg-elevated);
  transform-origin:right center;
}
.project-card__content{padding:24px;}
.project-card__tags{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;}
.project-card__tag{
  font-family:var(--ff-mono);font-size:0.7rem;background:var(--bg-elevated);
  color:var(--teal);padding:4px 10px;border-radius:4px;border:1px solid var(--line);
}
.project-card__title{
  font-family:var(--ff-display);font-size:1.3rem;margin-bottom:8px;
}
.project-card__desc{
