  /* ---------------------------------------------------------
     CUSTOM CURSOR
     --------------------------------------------------------- */
  function initCustomCursor(){
    var dot = document.getElementById('cursorDot');
    var ring = document.getElementById('cursorRing');
    if (!dot || !ring) return;
    if (!supportsHover || prefersReducedMotion) return;

    document.body.classList.add('has-custom-cursor');

    gsap.set([dot, ring], { xPercent: -50, yPercent: -50, x: window.innerWidth / 2, y: window.innerHeight / 2 });

    var setDotX = gsap.quickTo(dot, 'x', { duration: .12, ease: 'power3.out' });
    var setDotY = gsap.quickTo(dot, 'y', { duration: .12, ease: 'power3.out' });
    var setRingX = gsap.quickTo(ring, 'x', { duration: .35, ease: 'power3.out' });
    var setRingY = gsap.quickTo(ring, 'y', { duration: .35, ease: 'power3.out' });

    window.addEventListener('mousemove', function(e){
      setDotX(e.clientX); setDotY(e.clientY);
      setRingX(e.clientX); setRingY(e.clientY);
    });

    var interactive = document.querySelectorAll('a, button, .project-card, .service-card, .stat-card, input, textarea');
    interactive.forEach(function(el){
      el.addEventListener('mouseenter', function(){ ring.classList.add('is-active'); });
      el.addEventListener('mouseleave', function(){ ring.classList.remove('is-active'); });
    });
  }

  /* ---------------------------------------------------------
     MAGNETIC HERO BUTTONS
     --------------------------------------------------------- */
  function initMagnetic(){
    if (!supportsHover || prefersReducedMotion) return;
    var magnets = document.querySelectorAll('[data-magnetic]');
    magnets.forEach(function(el){
      var setX = gsap.quickTo(el, 'x', { duration: .3, ease: 'power3.out' });
      var setY = gsap.quickTo(el, 'y', { duration: .3, ease: 'power3.out' });
      var setScale = gsap.quickTo(el, 'scale', { duration: .3, ease: 'power3.out' });
      el.addEventListener('mousemove', function(e){
        var r = el.getBoundingClientRect();
        var relX = e.clientX - r.left - r.width / 2;
        var relY = e.clientY - r.top - r.height / 2;
        setX(relX * 0.35);
        setY(relY * 0.35);
        setScale(1.05);
      });
      el.addEventListener('mouseleave', function(){
        setX(0); setY(0); setScale(1);
      });
    });
  }

  /* ---------------------------------------------------------
     3D TILT (project cards + about code window)
     --------------------------------------------------------- */
  function initTilt(){
    if (!supportsHover || prefersReducedMotion) return;
    var cards = document.querySelectorAll('.project-card, .code-window');
    cards.forEach(function(card){
      var setRX = gsap.quickTo(card, 'rotationX', { duration: .4, ease: 'power3.out' });
      var setRY = gsap.quickTo(card, 'rotationY', { duration: .4, ease: 'power3.out' });
      var setY = gsap.quickTo(card, 'y', { duration: .4, ease: 'power3.out' });
      card.addEventListener('mousemove', function(e){
        var r = card.getBoundingClientRect();
        var px = (e.clientX - r.left) / r.width;
        var py = (e.clientY - r.top) / r.height;
        setRY((px - 0.5) * 14);
        setRX((0.5 - py) * 10);
        setY(-6);
      });
      card.addEventListener('mouseleave', function(){
        setRX(0); setRY(0); setY(0);
      });
    });
  }

  /* ---------------------------------------------------------
     CONTACT FORM (static demo submission)
     --------------------------------------------------------- */
  function initContactForm(){
    var form = document.getElementById('contactForm');
    var btn  = document.getElementById('submitBtn');
    if (!form || !btn) return;

    form.addEventListener('submit', function(e){
      e.preventDefault();
      if (!form.checkValidity()){
        form.reportValidity();
        return;
      }
      var original = btn.innerHTML;
      btn.innerHTML = 'message.sent <span class="dim">✓</span>';
      btn.classList.add('is-sent');
      btn.disabled = true;
      form.reset();
      setTimeout(function(){
        btn.innerHTML = original;
        btn.classList.remove('is-sent');
        btn.disabled = false;
      }, 2600);
    });
  }

  /* ---------------------------------------------------------
     BACK TO TOP
     --------------------------------------------------------- */
  function initBackToTop(){
    var btn = document.getElementById('backToTop');
    if (!btn) return;
    window.addEventListener('scroll', function(){
      btn.classList.toggle('is-visible', window.scrollY > 480);
    }, { passive: true });
    btn.addEventListener('click', function(){
      window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
    });
  }

  /* ---------------------------------------------------------
     MISC
     --------------------------------------------------------- */
  function initYear(){
    var y = document.getElementById('year');
    if (y) y.textContent = new Date().getFullYear();
  }

  function main(){
    initYear();
    initLetterSplit();
    initNav();
    initContactForm();
    initBackToTop();
    initScrollProgress();

    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined'){
      var introEl = document.getElementById('intro');
      if (introEl) introEl.style.display = 'none';
      document.body.classList.remove('lock-scroll');
      return;
    }

    gsap.registerPlugin(ScrollTrigger);
    initIntro();
    initParticleCanvas();
    initScrollReveals();
    initSkillBars();
    initCustomCursor();
    initMagnetic();
    initTilt();
    initImageReveal();
    initCounters();
    initTimelineProgress();
    initLogoSpin();
  }

  if (document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', main);
  } else {
    main();
  }
})();
</script>
</body>
</html>
